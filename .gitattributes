# Binary files (not subject to line ending conversion)
*.png binary
*.vhd binary

# Default: all files use LF
* text eol=lf

# Windows PowerShell and batch files use CRLF
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Keep Linux build/runtime files on LF even when edited on Windows.
tcfiles/* text eol=lf
tcfiles/** text eol=lf