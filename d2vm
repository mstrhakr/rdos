#!/bin/bash

set -euo pipefail

docker_args=(
	--rm
	-v /var/run/docker.sock:/var/run/docker.sock
	--privileged
	-v .:/d2vm
	-w /d2vm
)

# Use interactive flags only when a real TTY is present.
if [[ -t 0 && -t 1 ]]; then
	docker_args+=( -it )
elif [[ -t 0 ]]; then
	docker_args+=( -i )
fi

docker run "${docker_args[@]}" linkacloud/d2vm:latest "$@"
