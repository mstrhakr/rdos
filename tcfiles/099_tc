# Allow any user to factory reset and set the hostname, this way it can be done by thin client admins without needing to know the image password
ALL ALL=(ALL) NOPASSWD: /usr/bin/set-hostname
ALL ALL=(ALL) NOPASSWD: /usr/bin/firstboot
ALL ALL=(ALL) NOPASSWD: /usr/bin/auto-maintenance
ALL ALL=(ALL) NOPASSWD: /usr/bin/tc-configure-wifi
ALL ALL=(ALL) NOPASSWD: /usr/bin/tc-scan-wifi