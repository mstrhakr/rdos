# Limit passwordless maintenance to the thinclient user and expected command shapes.
thinclient ALL=(root) NOPASSWD: /usr/bin/set-hostname *
thinclient ALL=(root) NOPASSWD: /usr/bin/firstboot
thinclient ALL=(root) NOPASSWD: /usr/bin/auto-maintenance
thinclient ALL=(root) NOPASSWD: /usr/bin/tc-configure-network --apply-tcconfig * --reload
thinclient ALL=(root) NOPASSWD: /usr/bin/tc-configure-network --apply-tcconfig *
thinclient ALL=(root) NOPASSWD: /usr/bin/tc-configure-wifi --configure * * *
thinclient ALL=(root) NOPASSWD: /usr/bin/tc-configure-wifi --disable-powersave
thinclient ALL=(root) NOPASSWD: /usr/bin/tc-scan-wifi *
thinclient ALL=(root) NOPASSWD: /usr/bin/tc-configure-wifi --from-usb-drive *
thinclient ALL=(root) NOPASSWD: /usr/bin/tc-configure-wireguard --from-usb-drive *