#!/bin/bash

set -euo pipefail

PROGRESS_PID=""
PROGRESS_FD=""

resolve_privileged_runner() {
    if command -v sudo >/dev/null 2>&1; then
        printf '%s\n' sudo
        return 0
    fi

    if command -v pkexec >/dev/null 2>&1; then
        printf '%s\n' pkexec
        return 0
    fi

    if [ "$(id -u)" -eq 0 ]; then
        return 0
    fi

    return 1
}

run_privileged() {
    if [ "$(id -u)" -eq 0 ]; then
        "$@"
        return $?
    fi

    if [ -n "${PRIVILEGED_RUNNER:-}" ]; then
        "$PRIVILEGED_RUNNER" "$@"
        return $?
    fi

    return 1
}

start_progress() {
    local title="$1"
    local text="$2"
    local fifo

    # Ensure no previous progress dialog is left behind.
    finish_progress 0

    fifo=$(mktemp -u)
    mkfifo "$fifo"
    yad --progress --center --on-top --width=460 --title="$title" --text="$text" --percentage=0 <"$fifo" >/dev/null 2>&1 &
    PROGRESS_PID=$!
    exec {PROGRESS_FD}>"$fifo"
    rm -f "$fifo"
    printf '0\n' >&$PROGRESS_FD
}

update_progress() {
    local percent="$1"
    local text="${2:-}"

    if [ -n "$PROGRESS_FD" ]; then
        if [ -n "$text" ]; then
            printf '%s: %s\n' "$percent" "$text" >&$PROGRESS_FD
        else
            printf '%s\n' "$percent" >&$PROGRESS_FD
        fi
    fi
}

finish_progress() {
    local hold_seconds="${1:-1}"

    if [ -n "$PROGRESS_FD" ]; then
        printf '100\n' >&$PROGRESS_FD || true
        sleep "$hold_seconds"
        exec {PROGRESS_FD}>&-
        PROGRESS_FD=""
    fi

    if [ -n "$PROGRESS_PID" ]; then
        kill "$PROGRESS_PID" >/dev/null 2>&1 || true
        wait "$PROGRESS_PID" >/dev/null 2>&1 || true
        PROGRESS_PID=""
    fi
}

find_wireless_interface() {
    local device

    for device in /sys/class/net/*; do
        [ -d "$device/wireless" ] || continue
        basename "$device"
        return 0
    done

    return 1
}

list_wireless_interfaces() {
    local device

    for device in /sys/class/net/*; do
        [ -d "$device/wireless" ] || continue
        basename "$device"
    done
}

choose_wireless_interface() {
    local interfaces
    local choice

    mapfile -t interfaces < <(list_wireless_interfaces)

    if [ "${#interfaces[@]}" -eq 0 ]; then
        return 1
    fi

    if [ "${#interfaces[@]}" -eq 1 ]; then
        printf '%s\n' "${interfaces[0]}"
        return 0
    fi

    choice=$(printf '%s\n' "${interfaces[@]}" | yad --list --center --width=400 --height=250 --title="WiFi Wizard" \
        --text="Select the wireless adapter to scan." \
        --separator=$'\x1F' \
        --button="Cancel":1 --button="Scan":0 \
        --column="Adapter") || return 1

    printf '%s\n' "$(awk -F'\x1F' '{print $1}' <<<"$choice")"
}

show_scan_progress() {
    local iface="$1"
    local title="WiFi Wizard"

    start_progress "$title" "Scanning for WiFi networks on $iface..."
}

show_configure_progress() {
    local iface="$1"
    local ssid="$2"
    local title="WiFi Wizard"

    start_progress "$title" "Applying WiFi settings for $ssid on $iface..."
}

prompt_manual_network() {
    local output
    local status

    set +e
    output=$(yad --form --center --width=500 --title="WiFi Wizard" \
        --text="Enter the WiFi details manually." \
        --separator=$'\x1F' \
        --button="Cancel":1 --button="Next":0 \
        --field="SSID" "$manual_ssid" \
        --field="Password":h "$manual_password" \
        --field="Hidden Network:CHK" "$manual_hidden")
    status=$?
    set -e

    if ((status != 0)); then
        return 1
    fi

    manual_ssid="$(awk -F'\x1F' '{print $1}' <<<"$output")"
    manual_password="$(awk -F'\x1F' '{print $2}' <<<"$output")"
    manual_hidden="$(awk -F'\x1F' '{print tolower($3)}' <<<"$output")"
    return 0
}

prompt_password() {
    local help_text="$1"
    local output
    local status

    set +e
    output=$(yad --form --center --width=500 --title="WiFi Wizard" \
        --text="$help_text" \
        --separator=$'\x1F' \
        --button="Back":2 --button="Cancel":1 --button="Connect":0 \
        --field="Password":h "$network_password")
    status=$?
    set -e

    if ((status == 2)); then
        return 2
    fi

    if ((status != 0)); then
        return 1
    fi

    network_password="$(awk -F'\x1F' '{print $1}' <<<"$output")"
    return 0
}

show_success() {
    local iface="$1"
    local address
    local attempts=0
    local max_attempts=15

    while [ "$attempts" -lt "$max_attempts" ]; do
        update_progress 96 "Waiting for DHCP lease (${attempts}/${max_attempts})"
        address=$(ip -4 -o addr show dev "$iface" | awk '{print $4}' | head -n 1)
        if [ -n "$address" ]; then
            yad --info --center --title="WiFi Wizard" --text="Connected to $network_ssid on $iface.\nIPv4 address: $address"
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 1
    done

    yad --info --center --title="WiFi Wizard" --text="WiFi settings were saved for $network_ssid on $iface.\nDHCP has not assigned an IPv4 address yet.\nThe connection may take a bit longer on this network."
}

sanitize_ssid_for_list() {
    local ssid="$1"

    ssid="${ssid//$'\r'/ }"
    ssid="${ssid//$'\n'/ }"
    ssid="${ssid//|//}"
    printf '%s' "$ssid"
}

build_scan_rows() {
    local scan_text="$1"
    local ssid
    local signal
    local security
    local safe_ssid
    local index=0

    scanned_ssids=()

    while IFS=$'\t' read -r ssid signal security; do
        [ -n "$ssid" ] || continue
        safe_ssid="$(sanitize_ssid_for_list "$ssid")"
        scanned_ssids+=("$ssid")
        printf '%d\n%s\n%s\n%s\n' "$index" "$safe_ssid" "$signal" "$security"
        index=$((index + 1))
    done <<< "$scan_text"
}

PRIVILEGED_RUNNER="$(resolve_privileged_runner || true)"

iface="$(choose_wireless_interface || true)"
manual_ssid=""
manual_password=""
manual_hidden="FALSE"
network_password=""
network_ssid=""
network_hidden="false"
scanned_ssids=()

if [ -z "$iface" ]; then
    yad --error --center --title="WiFi Wizard" --text="No wireless adapter was detected on this device."
    exit 1
fi

while true; do
    show_scan_progress "$iface"
    update_progress 10 "Bringing adapter up"
    scan_results="$(run_privileged /usr/bin/tc-scan-wifi "$iface" 2>/tmp/rdos-wifi-scan.log || true)"
    update_progress 100 "Scan complete"
    finish_progress 1

    if [ -z "$scan_results" ]; then
        if [ -s /tmp/rdos-wifi-scan.log ]; then
            yad --warning --center --title="WiFi Wizard" --text="The adapter scan returned an error or no usable results.\n\nDetails:\n$(tail -n 5 /tmp/rdos-wifi-scan.log)"
        else
            yad --info --center --title="WiFi Wizard" --text="No WiFi networks were detected on $iface. You can enter the network details manually."
        fi
        if ! prompt_manual_network; then
            exit 0
        fi
        network_ssid="$manual_ssid"
        network_password="$manual_password"
        network_hidden="$manual_hidden"
        break
    fi

    scan_rows="$(build_scan_rows "$scan_results")"

    if [ -z "$scan_rows" ]; then
        if ! prompt_manual_network; then
            exit 0
        fi
        network_ssid="$manual_ssid"
        network_password="$manual_password"
        network_hidden="$manual_hidden"
        break
    fi

    set +e
    selection=$(printf '%s\n' "$scan_rows" | yad --list --center --width=700 --height=400 --title="WiFi Wizard" \
        --text="Select a wireless network for $iface." \
        --separator=$'\x1F' \
        --button="Manual Network":2 --button="Rescan":3 --button="Cancel":1 --button="Next":0 \
        --column="ID:NUM" --column="SSID" --column="Signal" --column="Security")
    status=$?
    set -e

    if ((status == 3)); then
        continue
    fi

    if ((status == 2)); then
        if ! prompt_manual_network; then
            exit 0
        fi
        network_ssid="$manual_ssid"
        network_password="$manual_password"
        network_hidden="$manual_hidden"
        break
    fi

    if ((status != 0)); then
        exit 0
    fi

    selected_index=""
    selected_signal=""
    selected_security=""

    if [[ "$selection" == *$'\x1F'* ]]; then
        IFS=$'\x1F' read -r selected_index _ selected_signal selected_security <<<"$selection"
    else
        IFS='|' read -r selected_index _ selected_signal selected_security <<<"$selection"
    fi

    if ! [[ "$selected_index" =~ ^[0-9]+$ ]]; then
        yad --error --center --title="WiFi Wizard" --text="Unable to parse the selected WiFi network. Please rescan or enter it manually."
        continue
    fi

    if [ -z "$selected_index" ] || [ "$selected_index" -ge "${#scanned_ssids[@]}" ]; then
        yad --error --center --title="WiFi Wizard" --text="Unable to parse the selected WiFi network. Please rescan or enter it manually."
        continue
    fi

    network_ssid="${scanned_ssids[$selected_index]}"
    network_security="$selected_security"
    network_hidden="false"

    if [ "$network_security" = "Open" ]; then
        network_password=""
        break
    fi

    if prompt_password "Enter the password for $network_ssid. Leave it blank only if the network is actually open."; then
        break
    fi

    password_status=$?
    if ((password_status == 2)); then
        continue
    fi
    exit 0
done

if [ -z "$network_ssid" ]; then
    yad --error --center --title="WiFi Wizard" --text="A network name is required."
    exit 1
fi

show_configure_progress "$iface" "$network_ssid"
update_progress 20 "Saving WiFi profile"

if ! configured_iface=$(printf '%s\n' "$network_password" | run_privileged /usr/bin/tc-configure-wifi --configure "$iface" "$network_ssid" "$network_hidden"); then
    finish_progress 0
    yad --error --center --title="WiFi Wizard" --text="Failed to save the WiFi configuration."
    exit 1
fi

update_progress 70 "Applying wireless settings"
update_progress 95 "Finalizing"
finish_progress 0
show_success "$configured_iface"