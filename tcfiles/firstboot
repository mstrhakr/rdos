#!/bin/bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Slot detection — honours A/B layout when grubenv is present
# ---------------------------------------------------------------------------
detect_active_slot() {
	local grubenv="/boot/grub/grubenv"
	if [[ -f "$grubenv" ]]; then
		local slot
		slot=$(grub-editenv "$grubenv" list 2>/dev/null | awk -F= '/^current_slot=/{print $2}')
		if [[ "$slot" == "a" || "$slot" == "b" ]]; then
			echo "$slot"
			return 0
		fi
	fi
	# Not an A/B image — return empty string so callers skip slot-specific logic
	echo ""
}

ACTIVE_SLOT="$(detect_active_slot)"

# Idempotency: if this slot has already completed firstboot, skip everything.
if [[ -n "$ACTIVE_SLOT" ]] && [[ -f "/boot/slots/${ACTIVE_SLOT}-init-done" ]]; then
	echo "Slot ${ACTIVE_SLOT} firstboot already complete, nothing to do."
	exit 0
fi

XANMOD_PACKAGE="linux-xanmod-lts-x64v1"
XANMOD_KEY_SHA256="ed26eb39330fd296cd037b8229adccea0197b21989ec0a1ad4f4f74f5a41c7a7"
XANMOD_KEY_FINGERPRINT="D38D7D1DA1349567ADED882D86F7D09EE734E623"

package_installed() {
	dpkg-query -W -f='${Status}' "$1" 2>/dev/null | grep -q '^install ok installed$'
}

refresh_initramfs() {
	if find /boot -maxdepth 1 -name 'initrd.img-*' -print -quit | grep -q .; then
		update-initramfs -u -k all
	else
		update-initramfs -c -k all
	fi
}

echo "Completing the final steps for the golden image."
echo "Once finished the machine will turn off, please wait until this is complete."
echo "If you see this and can not login after turning it back on contact the helpdesk."
if package_installed "$XANMOD_PACKAGE"; then
	echo "$XANMOD_PACKAGE is already present in the image, skipping package install."
else
	install -d -m 755 /etc/apt/keyrings
	wget -qO /tmp/xanmod-archive.key https://dl.xanmod.org/archive.key
	echo "$XANMOD_KEY_SHA256  /tmp/xanmod-archive.key" | sha256sum -c -
	if [[ "$(gpg --show-keys --with-colons /tmp/xanmod-archive.key | awk -F: '$1=="fpr"{print $10; exit}')" != "$XANMOD_KEY_FINGERPRINT" ]]; then
		echo "Unexpected XanMod key fingerprint." >&2
		exit 1
	fi
	gpg --dearmor -o /etc/apt/keyrings/xanmod-archive-keyring.gpg /tmp/xanmod-archive.key
	rm -f /tmp/xanmod-archive.key
	echo 'deb [signed-by=/etc/apt/keyrings/xanmod-archive-keyring.gpg] http://deb.xanmod.org releases main' > /etc/apt/sources.list.d/xanmod-release.list
	apt-get update

	if apt-cache show "$XANMOD_PACKAGE" >/dev/null 2>&1; then
		DEBIAN_FRONTEND=noninteractive apt-get install -y "$XANMOD_PACKAGE"
	else
		echo "Warning: $XANMOD_PACKAGE is not currently available from deb.xanmod.org."
		echo "Continuing with the kernel already present in the image."
	fi
fi

refresh_initramfs
setcap cap_net_raw+ep /usr/bin/mtr-packet
set-hostname thinclient

# Write slot init marker so subsequent boots are skipped
if [[ -n "$ACTIVE_SLOT" ]]; then
	mkdir -p /boot/slots
	touch "/boot/slots/${ACTIVE_SLOT}-init-done"
fi

rm "$0" && systemctl poweroff